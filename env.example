# TreeIdentifier Environment Variables
# Copy this file to .env.local for local development
# In Vercel, add these in Project Settings → Environment Variables

# Required: Your Groq API Key
# Get it at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: Site URL (used for canonical links)
NEXT_PUBLIC_SITE_URL=https://treeidentifier.com
